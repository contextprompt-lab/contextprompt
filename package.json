{
  "name": "contextprompt",
  "version": "0.1.0",
  "description": "CLI that captures meeting conversations, understands your codebase, and outputs structured coding tasks",
  "type": "module",
  "bin": {
    "contextprompt": "./dist/bin/contextprompt.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "keywords": [
    "meeting",
    "transcription",
    "coding-tasks",
    "claude",
    "cli"
  ],
  "scripts": {
    "build": "tsup && npm run build:web",
    "build:server": "tsup",
    "build:web": "cd website && npm run build",
    "dev": "npx concurrently -n server,web -c blue,green \"tsx bin/contextprompt.ts dashboard\" \"cd website && npm run dev\"",
    "start": "node dist/bin/contextprompt.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm test && npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ignore": "^7.0.5",
    "node-cron": "^4.2.1",
    "openai": "^6.30.1",
    "ora": "^9.3.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "typescript": "^5.9.3",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "audiotee": "^0.0.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.13",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4"
  }
}
