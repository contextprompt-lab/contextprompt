ANTHROPIC_API_KEY=your_anthropic_api_key_here
RECALL_API_KEY=your_recall_api_key_here
RECALL_REGION=us-east-1

# Google OAuth (required for authentication)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe (required for Pro plan payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_pro_plan_price_id

# App URL (used for OAuth redirect and Stripe callbacks)
APP_URL=http://localhost:3847

# Support contact form (Resend)
RESEND_API_KEY=re_your_resend_api_key
SUPPORT_EMAIL=support@contextprompt.com
